    <!-- FAQ -->
    <string name="faq_q1">How do I create a daily plan?</string>
    <string name="faq_a1">Tap the "+" button on the home screen and select activities for your day.</string>
    <string name="faq_q2">Can I sync my plans across devices?</string>
    <string name="faq_a2">Yes! Sign in with your account to sync plans automatically.</string>
    <string name="faq_q3">How do I change my theme?</string>
    <string name="faq_a3">Go to Profile → Settings → Theme to switch between Light, Dark or System mode.</string>

