    <!-- FAQ -->
    <string name="faq_q1">Jak utworzyć plan dzienny?</string>
    <string name="faq_a1">Dotknij przycisku „+” na ekranie głównym i wybierz aktywności na dany dzień.</string>

    <string name="faq_q2">Czy mogę synchronizować plany między urządzeniami?</string>
    <string name="faq_a2">Tak! Zaloguj się na swoje konto, aby automatycznie synchronizować plany.</string>

    <string name="faq_q3">Jak zmienić motyw aplikacji?</string>
    <string name="faq_a3">Przejdź do Profil → Ustawienia → Motyw, aby wybrać tryb Jasny, Ciemny lub Systemowy.</string>

